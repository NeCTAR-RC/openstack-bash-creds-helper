#!/bin/bash
# shellcheck disable=SC1090

function chcreds() {
    local creds
    if ! creds=$(oscreds "$@"); then
        echo "Failed to load credentials" >&2
        return 1
    fi
    source <(printf '%s\n' "$creds")
    echo "Credentials loaded for $OS_CRED"
}

function recred() {
    chcreds "$OS_CRED"
}

function rmcreds() {
    local v
    for v in ${!OS_@}; do
        unset "$v"
    done
}

function prcreds() {
    local varname
    for varname in ${!OS_@}; do
        if [[ "$varname" == *PASSWORD* || "$varname" == *TOKEN* || "$varname" == *SECRET* ]]; then
            printf '%s=******\n' "$varname"
        else
            # ${!varname} dynamically looks up the value of the variable
            printf '%s=%s\n' "$varname" "${!varname}"
        fi
    done
}

function os_creds() {
    printf '%s' "${OS_CRED:+ $OS_CRED}"
}

